# OH AI Agent — Environment Configuration
# Copy to .env and fill in values.

# General
OH_ENVIRONMENT=development
OH_DEBUG=true
OH_LOG_LEVEL=INFO

# API
OH_API_HOST=0.0.0.0
OH_API_PORT=8000

# LLM — any OpenAI-compatible provider
# API key (OH_LLM_API_KEY takes precedence over OH_OPENAI_API_KEY)
OH_LLM_API_KEY=
OH_OPENAI_API_KEY=

# Custom base URL — set this to use a non-OpenAI provider:
#   OpenAI (default):       (leave empty)
#   OpenRouter:             https://openrouter.ai/api/v1
#   Anthropic:              https://api.anthropic.com/v1
#   Azure OpenAI:           https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT
#   Together:               https://api.together.xyz/v1
#   Groq:                   https://api.groq.com/openai/v1
#   Local (Ollama):         http://localhost:11434/v1
OH_LLM_BASE_URL=

# Model name (must match your provider's model identifiers)
OH_LLM_MODEL=gpt-4o
OH_LLM_TEMPERATURE=0.1
OH_LLM_MAX_TOKENS=4096

# Knowledge / RAG
OH_KNOWLEDGE_DIR=knowledge_base
OH_CHROMA_PERSIST_DIR=.chroma_db
OH_CHROMA_COLLECTION=oh_knowledge
OH_RETRIEVAL_TOP_K=8
OH_CHUNK_SIZE=800
OH_CHUNK_OVERLAP=200

# Audit
OH_AUDIT_LOG_FILE=logs/audit.jsonl
