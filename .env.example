# OH AI Agent — Environment Configuration
# Copy to .env and fill in values.

# General
OH_ENVIRONMENT=development
OH_DEBUG=true
OH_LOG_LEVEL=INFO

# API
OH_API_HOST=0.0.0.0
OH_API_PORT=8000

# LLM — LiteLLM routes by provider + model (switch models without code changes)
# Provider: litellm (default) | openrouter | openai (OpenAI SDK only)
OH_LLM_PROVIDER=openrouter

# API key (OH_LLM_API_KEY takes precedence over OH_OPENAI_API_KEY)
OH_LLM_API_KEY=
OH_OPENAI_API_KEY=

# Model id — examples:
#   OpenAI (litellm + OH_LLM_API_KEY):     gpt-4o, gpt-4o-mini
#   OpenRouter (OH_LLM_PROVIDER=openrouter): anthropic/claude-sonnet-4, google/gemini-2.0-flash-001
#   Groq (litellm):                        groq/llama-3.3-70b-versatile
#   OpenRouter via litellm prefix:         openrouter/anthropic/claude-sonnet-4
# OpenRouter model ids: openai/gpt-4o-mini, anthropic/claude-sonnet-4, openrouter/auto
OH_LLM_MODEL=openai/gpt-4o-mini

# Optional API base (OpenRouter preset sets https://openrouter.ai/api/v1 when empty)
#   Groq:    https://api.groq.com/openai/v1
#   Ollama:  http://localhost:11434/v1
OH_LLM_BASE_URL=

# --- OpenRouter quick start ---
# OH_LLM_PROVIDER=openrouter
# OH_LLM_API_KEY=sk-or-v1-...
# OH_LLM_MODEL=anthropic/claude-sonnet-4
OH_LLM_TEMPERATURE=0.1
OH_LLM_MAX_TOKENS=4096

# Knowledge / RAG
OH_KNOWLEDGE_DIR=knowledge_base
OH_CHROMA_PERSIST_DIR=.chroma_db
OH_CHROMA_COLLECTION=oh_knowledge
OH_RETRIEVAL_TOP_K=8
OH_CHUNK_SIZE=800
OH_CHUNK_OVERLAP=200
OH_INGEST_ON_STARTUP=false

# Audit
OH_AUDIT_LOG_FILE=logs/audit.jsonl

# --- Production (Railway) ---
# Mount a volume at /app/data and set:
#   OH_ENVIRONMENT=production
#   OH_DEBUG=false
#   OH_CHROMA_PERSIST_DIR=/app/data/chroma
#   OH_AUDIT_LOG_FILE=/app/data/logs/audit.jsonl
#   OH_INGEST_ON_STARTUP=false
# See docs/DEPLOY_VERCEL_RAILWAY.md for full Vercel + Railway setup.
